# ============================================
# Environment Variables for Production
# ============================================
# Copy this file to .env and fill in your values
# On Vercel: Settings → Environment Variables

# ---- Database (choose one) ----
# Option A: Vercel Postgres (recommended, free tier)
DATABASE_URL="postgres://user:pass@host/db"

# Option B: MongoDB Atlas (free tier)
# DATABASE_URL="mongodb+srv://user:pass@cluster.mongodb.net/cryptoMine"

# Option C: Supabase (free tier)
# DATABASE_URL="postgresql://user:pass@db.supabase.co/postgres"

# ---- Authentication ----
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Telegram OAuth
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your-bot-username"

# Apple Sign In
APPLE_CLIENT_ID="your-apple-client-id"
APPLE_CLIENT_SECRET="your-apple-client-secret"

# ---- Payment Gateways ----
BINANCE_PAY_API_KEY="your-binance-api-key"
BINANCE_PAY_SECRET_KEY="your-binance-secret-key"

COINBASE_COMMERCE_API_KEY="your-coinbase-commerce-key"
COINBASE_COMMERCE_WEBHOOK_SECRET="your-webhook-secret"

# ---- Email (for notifications & password reset) ----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ---- Security ----
RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"

# ---- App Config ----
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_NAME="CryptoMine 2026"
