// ============================================
// Crypto Mining Investment Platform - Database Schema
// ============================================
// Uses String instead of enums for maximum compatibility
// Works with: PostgreSQL (Vercel Postgres, Neon, Supabase)
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User Model
// ============================================
model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String?
  avatar          String?
  phone           String?
  country         String?
  
  // Account type - using String instead of enum
  role            String   @default("USER")
  isAdmin         Boolean  @default(false)
  
  // Balance & profits
  balance         Float    @default(0)
  totalProfit     Float    @default(0)
  dailyProfit     Float    @default(0)
  monthlyProfit   Float    @default(0)
  points          Int      @default(0)
  vipLevel        Int      @default(1)
  
  // Referral system
  referralCode    String   @unique
  referredById    String?
  referredBy      User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]   @relation("Referrals")
  
  // Security
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  emailVerified    Boolean @default(false)
  isBlocked        Boolean @default(false)
  isBanned         Boolean @default(false)
  
  // OAuth providers
  googleId         String?
  telegramId       String?
  appleId          String?
  
  // Activity
  lastLogin        DateTime?
  lastActive       DateTime?
  
  // Mining plan
  activePlanId     String?
  activePlan       Plan?   @relation(fields: [activePlanId], references: [id])
  planActivatedAt  DateTime?
  planExpiresAt    DateTime?
  
  // Daily Mining System (24h activation)
  lastMiningActivation DateTime?  // When user last activated daily mining
  miningExpiresAt      DateTime?  // When current 24h mining session expires
  miningAutoRenew      Boolean  @default(false)  // Auto-activate daily mining
  accumulatedProfit    Float    @default(0)  // Profits ready to withdraw (separate from capital)
  totalMiningDays      Int      @default(0)  // Total days mined
  
  // Timestamps
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Relations
  deposits         Deposit[]
  withdrawals      Withdrawal[]
  transactions     Transaction[]
  tasks            UserTask[]
  notifications    Notification[]
  referralEarnings        ReferralEarning[] @relation("ReferrerEarnings")
  referredInEarnings      ReferralEarning[] @relation("ReferredInEarnings")
  rewards          Reward[]
  
  @@index([email])
  @@index([referralCode])
  @@index([referredById])
}

// ============================================
// Mining Plans
// ============================================
model Plan {
  id            String   @id @default(cuid())
  name          String
  nameAr        String
  investment    Float
  dailyProfit   Float
  duration      Int
  hashrate      String
  color         String
  gradient      String
  icon          String
  popular       Boolean  @default(false)
  active        Boolean  @default(true)
  features      Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  users         User[]
}

// ============================================
// Deposits
// ============================================
model Deposit {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String
  network       String
  txHash        String?
  address       String
  status        String   @default("PENDING")
  confirmations Int      @default(0)
  requiredConfirmations Int @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
}

// ============================================
// Withdrawals
// ============================================
model Withdrawal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String
  network       String
  address       String
  fee           Float
  status        String   @default("PENDING")
  txHash        String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
}

// ============================================
// Transactions (all types)
// ============================================
model Transaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  amount        Float
  currency      String
  status        String   @default("COMPLETED")
  description   String?
  txHash        String?
  createdAt     DateTime @default(now())
  
  @@index([userId])
  @@index([type])
}

// ============================================
// Referral Earnings
// ============================================
model ReferralEarning {
  id            String   @id @default(cuid())
  referrerId    String
  referrer      User     @relation("ReferrerEarnings", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId    String
  referred      User     @relation("ReferredInEarnings", fields: [referredId], references: [id])
  level         Int
  percentage    Float
  amount        Float
  source        String
  createdAt     DateTime @default(now())
  
  @@index([referrerId])
  @@index([referredId])
}

// ============================================
// Tasks
// ============================================
model Task {
  id            String   @id @default(cuid())
  title         String
  titleAr       String
  description   String
  descriptionAr String
  type          String
  reward        Float
  rewardType    String
  icon          String
  total         Int?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userTasks     UserTask[]
}

model UserTask {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id])
  progress      Int      @default(0)
  completed     Boolean  @default(false)
  claimed       Boolean  @default(false)
  completedAt   DateTime?
  claimedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([userId, taskId])
  @@index([userId])
}

// ============================================
// Notifications
// ============================================
model Notification {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  title         String
  message       String
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
  
  @@index([userId])
  @@index([read])
}

// ============================================
// Admin Settings (single row)
// ============================================
model AdminSettings {
  id                    String   @id @default("singleton")
  platformName          String   @default("CryptoMine 2026")
  maintenanceMode       Boolean  @default(false)
  signupEnabled         Boolean  @default(true)
  minWithdrawalUsd      Float    @default(20)
  defaultWithdrawalFee  Float    @default(1)
  recaptchaEnabled      Boolean  @default(false)
  binanceApiKey         String?
  coinbaseApiKey        String?
  telegramBotToken      String?
  telegramBotUsername   String?
  smtpHost              String?
  smtpPort              Int?
  smtpUser              String?
  smtpPass              String?
  
  // Mining Control Settings
  miningMode            String   @default("manual") // "manual" or "auto"
  miningStartTime       Int      @default(0) // Hour of day (0-23) when mining starts
  miningDurationHours   Int      @default(24) // Duration in hours (default 24)
  miningAutoRenewDefault Boolean @default(false) // Default auto-renew for new plans
  minMiningBalance      Float    @default(0.01) // Min balance to withdraw mining profits
  
  updatedAt             DateTime @updatedAt
}

// ============================================
// Sessions (for JWT-based auth)
// ============================================
model Session {
  id            String   @id @default(cuid())
  userId        String
  token         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

// ============================================
// Wallet Addresses (real deposit addresses managed by admin)
// ============================================
model WalletAddress {
  id            String   @id @default(cuid())
  currency      String   // BTC, ETH, USDT-TRC20, USDT-ERC20, BNB, LTC
  network       String
  address       String
  qrCode        String?
  label         String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([currency])
  @@index([active])
}

// ============================================
// Admin Activity Log
// ============================================
model AdminLog {
  id            String   @id @default(cuid())
  adminId       String
  action        String
  target        String?
  details       String?
  createdAt     DateTime @default(now())
  
  @@index([adminId])
  @@index([createdAt])
}

// ============================================
// Rewards (admin-created gifts for users)
// ============================================
model Reward {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  titleAr       String
  description   String
  descriptionAr String
  amount        Float
  currency      String   @default("USDT")
  type          String   @default("GIFT") // GIFT, BONUS, MILESTONE
  icon          String   @default("🎁")
  claimed       Boolean  @default(false)
  claimedAt     DateTime?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  
  @@index([userId])
  @@index([claimed])
}
